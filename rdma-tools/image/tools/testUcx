#!/bin/bash

# --- Configuration ---
BASE_PORT=${BASE_PORT:-13337}
REPORT_FILE=${REPORT_FILE:-"/tmp/ucx_rdma_benchmark_report.json"}
TMP_RAW_LOG=${TMP_RAW_LOG:-"/tmp/ucx_raw.log"}
SERVER_LOG=${SERVER_LOG:-"/tmp/ucx_server_output.log"}

HOSTS_FILE=${HOSTS_FILE:-""}
SSH_USER=${SSH_USER:-"root"}
SSH_PORT=${SSH_PORT:-2022}

TESTS=${TESTS:-"tag_lat tag_bw"}
SAME_NETWORK_TRACK=${SAME_NETWORK_TRACK:-"true"}
SAME_RAIL_ONLY=${SAME_RAIL_ONLY:-"true"}

RDMA_MODE=${RDMA_MODE:-"infiniband"}

LAT_MSG_SIZE=${LAT_MSG_SIZE:-"64"}
BW_MSG_SIZE=${BW_MSG_SIZE:-"8388608"}
NUM_ITERS=${NUM_ITERS:-10000}
WORKDIR=${WORKDIR:-"/tmp/testUcx-$(date +%Y%m%d%H%M%S%N)"}
DEBUG=${DEBUG:-"false"}

print_help() {
    cat <<EOF
Usage:
  testUcx [--help|-h]

Description:
  Single-host driver mode UCX RDMA benchmark.
  Reads HOSTS_FILE (management IPs used only for SSH), pairs hosts 2-by-2,
  starts ucx_perftest server on the server host, runs client on the client host,
  and writes a JSON report.

Required:
  HOSTS_FILE=<path>     File containing management IPs, one per line. Host count must be even.

Common environment variables:
  SSH_USER=root|...                 SSH user for remote execution (default: root)
  SSH_PORT=2022|...                 SSH port (default: 2022)
  RDMA_MODE=infiniband|ethernet     Filter RDMA devices by link_layer (default: infiniband)
  SAME_NETWORK_TRACK=true|false     Require client/server IPs in same subnet (default: true)
  SAME_RAIL_ONLY=true|false         Only test client_dev == server_dev (default: true)
  TESTS="tag_lat tag_bw"            Which tests to run (default: "tag_lat tag_bw")
  NUM_ITERS=2000|...                Iterations per test (default: 10000)
  LAT_MSG_SIZE=64|...               tag_lat message size (default: 64)
  BW_MSG_SIZE=8388608|...           tag_bw message size (default: 8388608)
  BASE_PORT=13337|...               Base port for ucx_perftest servers (default: 13337)
  DEBUG=true|false                  Verbose diagnostics (default: false)
  WORKDIR=/tmp/testUcx-...          Work directory (default: auto)
  REPORT_FILE=/tmp/...json          JSON report output path (default: /tmp/ucx_rdma_benchmark_report.json)
  TMP_RAW_LOG=/tmp/...log           Raw log output path (default: /tmp/ucx_raw.log)

Examples:
  RDMA_MODE=infiniband HOSTS_FILE=/hosts SAME_RAIL_ONLY=true NUM_ITERS=2000 testUcx
  RDMA_MODE=ethernet   HOSTS_FILE=/hosts SAME_NETWORK_TRACK=true DEBUG=true testUcx

Output:
  Prints a JSON report to stdout and writes the report to REPORT_FILE.
EOF
}

have_cmd() {
    command -v "$1" >/dev/null 2>&1
}

log() {
    printf '%s\n' "$*" >&2
}

debug_log() {
    if [ "${DEBUG}" = "true" ]; then
        printf '%s\n' "$*" >&2
    fi
}

rawlog() {
    printf '%s\n' "$*" >>"${TMP_RAW_LOG}"
}

ssh_base_cmd() {
    local host=$1
    shift || true
    ssh \
        -T \
        -o BatchMode=yes \
        -o ConnectTimeout=5 \
        -o ServerAliveInterval=5 \
        -o ServerAliveCountMax=1 \
        -p "${SSH_PORT}" \
        "${SSH_USER}@${host}" \
        "$@"
}

ssh_run() {
    local host=$1
    shift || true
    ssh_base_cmd "${host}" "$@"
}

fatal() {
    log "[UCX][Fatal] $*"
    exit 1
}

is_fatal_runtime_error() {
    local file=${1:-""}
    [ -n "${file}" ] && [ -f "${file}" ] || return 1
    grep -qiE 'ssh: |connection refused|permission denied|no route to host|could not resolve hostname|command not found|No such file or directory|not found|Connection closed|Operation timed out|timed out' "${file}" 2>/dev/null
}

tail_one_line() {
    local file=${1:-""}
    if [ -n "${file}" ] && [ -f "${file}" ]; then
        tail -n 1 "${file}" 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | sed 's/^ //; s/ $//'
    fi
}

ssh_precheck_host() {
    local host=$1
    local out_file="${WORKDIR}/ssh_${host}.out"
    local err_file="${WORKDIR}/ssh_${host}.err"
    : >"${out_file}"
    : >"${err_file}"

    if ssh_run "${host}" "/bin/sh -c 'echo __TESTUCX_SSH_OK__ ; command -v ip >/dev/null 2>&1'" >"${out_file}" 2>"${err_file}"; then
        if grep -q '__TESTUCX_SSH_OK__' "${out_file}"; then
            return 0
        fi
    fi
    return 1
}

REMOTE_SERVER_PIDS=()

stop_remote_server() {
    local host=$1
    local pid=${2:-""}
    if [ -n "${pid}" ]; then
        ssh_run "${host}" "kill -9 ${pid} >/dev/null 2>&1 || true" >/dev/null 2>&1 || true
        return 0
    fi
    ssh_run "${host}" "pkill -9 ucx_perftest >/dev/null 2>&1 || true" >/dev/null 2>&1 || true
}

cleanup() {
    trap - SIGINT SIGTERM
    set +o errexit
    local x
    for x in "${REMOTE_SERVER_PIDS[@]}"; do
        host=${x%%:*}
        pid=${x#*:}
        stop_remote_server "${host}" "${pid}"
    done
    exit 130
}
trap cleanup SIGINT SIGTERM

case "${1:-}" in
    -h|--help)
        print_help
        exit 0
        ;;
    "")
        ;;
    *)
        echo "Error: unknown argument: $1" >&2
        echo "Hint: use --help to see usage." >&2
        exit 2
        ;;
esac

[ ! -x "$(command -v jq)" ] && { echo "Error: jq is not installed."; exit 1; }

if [ -z "${HOSTS_FILE}" ] || [ ! -f "${HOSTS_FILE}" ]; then
    echo "Error: HOSTS_FILE is required and must exist."
    exit 1
fi

mkdir -p "${WORKDIR}" >/dev/null 2>&1 || true
echo "=== UCX RAW LOG START: $(date) ===" >"${TMP_RAW_LOG}"
echo "[]" >"${REPORT_FILE}"

read_hosts_file() {
    local f=${1:-""}
    awk '{print $1}' "${f}" | sed 's/[[:space:]]*$//' | grep -v '^$' | grep -v '^#' || true
}

same_subnet() {
    local a=$1
    local b=$2
    local mask=$3
    python3 - <<PY 2>/dev/null
import ipaddress
a='${a}'
b='${b}'
m='${mask}'
try:
    na=ipaddress.ip_network(f"{a}/{m}", strict=False)
    nb=ipaddress.ip_network(f"{b}/{m}", strict=False)
    print('1' if na.network_address==nb.network_address and na.prefixlen==nb.prefixlen else '0')
except Exception:
    print('0')
PY
}

remote_rdma_info() {
    local host=$1
    local debug_file="${WORKDIR}/rdma_${host}.debug"
    : >"${debug_file}"
    ssh_run "${host}" "bash -s -- '${RDMA_MODE}'" 2>"${debug_file}" <<'EOF' || true
MODE="${1:-infiniband}"

for d in $(ls /sys/class/infiniband 2>/dev/null | sort); do
    ll=$(cat "/sys/class/infiniband/${d}/ports/1/link_layer" 2>/dev/null || echo "")
    if [ "${MODE}" = "infiniband" ] && [ "${ll}" != "InfiniBand" ]; then
        continue
    fi
    if [ "${MODE}" = "ethernet" ] && [ "${ll}" != "Ethernet" ]; then
        continue
    fi

    iface=$(ls "/sys/class/infiniband/${d}/device/net" 2>/dev/null | head -n1)
    [ -n "${iface}" ] || continue

    pair=$(ip -4 -o addr show dev "${iface}" 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -n1)
    mask=$(ip -4 -o addr show dev "${iface}" 2>/dev/null | awk '{print $4}' | cut -d/ -f2 | head -n1)
    [ -n "${pair}" ] || continue
    [ -n "${mask}" ] || continue

    echo "${d} ${iface} ${pair} ${mask} ${ll}"
done
EOF
}

wait_remote_server_ready() {
    local host=$1
    local port=$2
    local pid=$3

    local i
    for i in $(seq 1 50); do
        if ! ssh_run "${host}" "kill -0 ${pid} 2>/dev/null" >/dev/null 2>&1; then
            return 1
        fi
        if ssh_run "${host}" "ss -ltn 2>/dev/null | awk '{print \$4}' | grep -qE '(:|\\.)${port}$'" >/dev/null 2>&1; then
            return 0
        fi
        if ssh_run "${host}" "netstat -ltn 2>/dev/null | awk '{print \$4}' | grep -qE '(:|\\.)${port}$'" >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.1
    done
    return 1
}

parse_ucx_output() {
    local test=$1
    local file=$2
    if [ "${test}" = "tag_lat" ]; then
        awk '$1 ~ /^[0-9]+$/ && NF>=3 {v=$3} END {if(v=="") exit 1; printf "%.6f\n", v+0}' "${file}" 2>/dev/null || \
        awk '$1=="Final:" && NF>=5 {print $4}' "${file}" 2>/dev/null
    else
        awk '$1 ~ /^[0-9]+$/ && NF>=6 {v=$6} END {if(v=="") exit 1; printf "%.6f\n", v+0}' "${file}" 2>/dev/null || \
        awk '$1=="Final:" && NF>=7 {print $6}' "${file}" 2>/dev/null
    fi
}

run_pair_case() {
    local client_host=$1
    local server_host=$2
    local client_dev=$3
    local client_ip=$4
    local client_mask=$5
    local server_dev=$6
    local server_ip=$7
    local server_mask=$8
    local port=$9

    local test
    for test in ${TESTS}; do
        local size
        if [ "${test}" = "tag_lat" ]; then
            size="${LAT_MSG_SIZE}"
        else
            size="${BW_MSG_SIZE}"
        fi

        local server_log="${WORKDIR}/server_${server_host}_${server_dev}_${test}_${port}.log"
        local client_log="${WORKDIR}/client_${client_host}_${client_dev}_${test}_${port}.log"
        local remote_server_log="/tmp/ucx_server_output_${server_dev}_${test}_${port}.log"
        local remote_server_debug="${WORKDIR}/server_${server_host}_${server_dev}_${test}_${port}.debug"

        rawlog "=== START TEST: ${client_host}(${client_dev}/${client_ip}) -> ${server_host}(${server_dev}/${server_ip}) ${test} port=${port} ==="
        log "[UCX] ${client_host}(${client_dev}/${client_ip}) -> ${server_host}(${server_dev}/${server_ip}) test=${test} port=${port}"

        local pid
        : >"${remote_server_debug}"
        pid=$(ssh_run "${server_host}" "env UCX_NET_DEVICES=${server_dev}:1 nohup ucx_perftest -p ${port} -t ${test} -s ${size} -n ${NUM_ITERS} -f >${remote_server_log} 2>&1 & echo \$!" 2>"${remote_server_debug}" || echo "")
        if [ -z "${pid}" ]; then
            fatal "failed to start server on ${server_host} dev=${server_dev}: $(tail_one_line "${remote_server_debug}")"
        fi
        REMOTE_SERVER_PIDS+=("${server_host}:${pid}")

        if ! wait_remote_server_ready "${server_host}" "${port}" "${pid}"; then
            ssh_run "${server_host}" "cat ${remote_server_log} 2>/dev/null || true" >"${server_log}" 2>"${remote_server_debug}" || true
            fatal "server not ready on ${server_host} dev=${server_dev} port=${port} pid=${pid}: $(tail_one_line "${server_log}") $(tail_one_line "${remote_server_debug}")"
        fi

        debug_log "[UCX][Debug] server_pid=${pid} remote_server_log=${remote_server_log}"
        debug_log "[UCX][Debug] client_cmd: UCX_NET_DEVICES=${client_dev}:1 ucx_perftest ${server_ip} -p ${port} -t ${test} -s ${size} -n ${NUM_ITERS}"
        if ! ssh_run "${client_host}" "env UCX_NET_DEVICES=${client_dev}:1 ucx_perftest ${server_ip} -p ${port} -t ${test} -s ${size} -n ${NUM_ITERS}" >"${client_log}" 2>&1; then
            stop_remote_server "${server_host}" "${pid}"
            ssh_run "${server_host}" "cat ${remote_server_log} 2>/dev/null || true" >"${server_log}" 2>&1 || true
            if is_fatal_runtime_error "${client_log}" || is_fatal_runtime_error "${server_log}"; then
                fatal "client/server runtime failure for ${test} ${client_host}(${client_dev}) -> ${server_host}(${server_dev}): client='$(tail_one_line "${client_log}")' server='$(tail_one_line "${server_log}")'"
            fi
        fi

        stop_remote_server "${server_host}" "${pid}"
        ssh_run "${server_host}" "cat ${remote_server_log} 2>/dev/null || true" >"${server_log}" 2>&1 || true

        local metric
        metric=$(parse_ucx_output "${test}" "${client_log}" 2>/dev/null || echo "")
        if [ -z "${metric}" ]; then
            if is_fatal_runtime_error "${client_log}" || is_fatal_runtime_error "${server_log}"; then
                fatal "fatal runtime error while parsing ${test} ${client_host}(${client_dev}) -> ${server_host}(${server_dev}): client='$(tail_one_line "${client_log}")' server='$(tail_one_line "${server_log}")'"
            fi
            local err
            err=$(tail -n 1 "${client_log}" 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g' | sed 's/^ //; s/ $//' )
            log "[UCX][Fail] ${test} ${client_host}(${client_dev}) -> ${server_host}(${server_dev}) : ${err}"
            NEW_JSON=$(jq -n --arg test "${test}" --arg client "${client_host}" --arg server "${server_host}" --arg client_dev "${client_dev}" --arg server_dev "${server_dev}" --arg client_ip "${client_ip}" --arg server_ip "${server_ip}" --argjson port "${port}" --arg err "${err}" '{pair:{client:$client,server:$server},test_type:$test,status:"FAILED",error:$err,case:{client_dev:$client_dev,server_dev:$server_dev,client_ip:$client_ip,server_ip:$server_ip,port:$port}}')
        else
            if [ "${test}" = "tag_lat" ]; then
                lat_us=$(python3 - <<PY 2>/dev/null
v=float('${metric}')
print(f"{v:.3f}")
PY
)
                lat_us=${lat_us:-0.000}
                log "[UCX][OK] ${test} lat_us=${lat_us}"
                NEW_JSON=$(jq -n --arg test "${test}" --arg client "${client_host}" --arg server "${server_host}" --arg client_dev "${client_dev}" --arg server_dev "${server_dev}" --arg client_ip "${client_ip}" --arg server_ip "${server_ip}" --argjson port "${port}" --argjson lat_us "${lat_us}" '{pair:{client:$client,server:$server},test_type:$test,status:"SUCCESS",case:{client_dev:$client_dev,server_dev:$server_dev,client_ip:$client_ip,server_ip:$server_ip,port:$port},metrics:{lat_avg_us:$lat_us}}')
            else
                bw_gbps=$(python3 - <<PY 2>/dev/null
v=float('${metric}')
print(f"{(v*8/1000):.3f}")
PY
)
                bw_gbps=${bw_gbps:-0.000}
                log "[UCX][OK] ${test} bw_gbps=${bw_gbps}"
                NEW_JSON=$(jq -n --arg test "${test}" --arg client "${client_host}" --arg server "${server_host}" --arg client_dev "${client_dev}" --arg server_dev "${server_dev}" --arg client_ip "${client_ip}" --arg server_ip "${server_ip}" --argjson port "${port}" --argjson bw_gbps "${bw_gbps}" '{pair:{client:$client,server:$server},test_type:$test,status:"SUCCESS",case:{client_dev:$client_dev,server_dev:$server_dev,client_ip:$client_ip,server_ip:$server_ip,port:$port},metrics:{bw_gbps:$bw_gbps}}')
            fi
        fi

        echo "$(jq --argjson new "${NEW_JSON}" '. += [$new]' "${REPORT_FILE}")" >"${REPORT_FILE}"

        rawlog "=== END TEST: ${test} ==="
        sleep 1
    done
}

run_pair_hosts() {
    local client_host=$1
    local server_host=$2
    local client_info_file="${WORKDIR}/rdma_${client_host}.txt"
    local server_info_file="${WORKDIR}/rdma_${server_host}.txt"

    rawlog "=== PAIR: ${client_host} -> ${server_host} ==="
    log "=== PAIR: ${client_host} -> ${server_host} ==="

    local port=${BASE_PORT}
    local sline cline
    local considered=0
    local filtered=0
    local executed=0

    while IFS= read -r sline; do
        [ -n "${sline}" ] || continue
        server_dev=$(echo "${sline}" | awk '{print $1}')
        server_ip=$(echo "${sline}" | awk '{print $3}')
        server_mask=$(echo "${sline}" | awk '{print $4}')
        [ -n "${server_dev}" ] || continue
        [ -n "${server_ip}" ] || continue

        while IFS= read -r cline; do
            [ -n "${cline}" ] || continue
            client_dev=$(echo "${cline}" | awk '{print $1}')
            client_ip=$(echo "${cline}" | awk '{print $3}')
            client_mask=$(echo "${cline}" | awk '{print $4}')
            [ -n "${client_dev}" ] || continue
            [ -n "${client_ip}" ] || continue

            if [ "${SAME_RAIL_ONLY}" = "true" ] && [ "${client_dev}" != "${server_dev}" ]; then
                filtered=$((filtered + 1))
                continue
            fi

            if [ "${SAME_NETWORK_TRACK}" = "true" ]; then
                if [ "${client_mask}" != "${server_mask}" ]; then
                    filtered=$((filtered + 1))
                    continue
                fi
                if [ "$(same_subnet "${client_ip}" "${server_ip}" "${client_mask}")" != "1" ]; then
                    filtered=$((filtered + 1))
                    continue
                fi
            fi

            considered=$((considered + 1))
            run_pair_case "${client_host}" "${server_host}" "${client_dev}" "${client_ip}" "${client_mask}" "${server_dev}" "${server_ip}" "${server_mask}" "${port}"
            port=$((port + 1))
            executed=$((executed + 1))
        done <"${client_info_file}"
    done <"${server_info_file}"

    log "[UCX] pair summary: considered=${considered} filtered=${filtered} executed=${executed}"
    if [ "${DEBUG}" = "true" ]; then
        debug_log "[UCX][Debug] client RDMA info (${client_host}):" 
        debug_log "$(cat "${client_info_file}" 2>/dev/null || true)"
        debug_log "[UCX][Debug] server RDMA info (${server_host}):" 
        debug_log "$(cat "${server_info_file}" 2>/dev/null || true)"
    fi
}

finalize_report() {
    local tmp
    tmp="${WORKDIR}/report_grouped.json"
    jq '
      def avg(v): if (v|length)==0 then null else ((v|add)/(v|length)) end;
      def rail_key: (.case.client_dev + ":" + .case.server_dev + ":" + .case.client_ip + ":" + .case.server_ip);

      group_by([.pair.client, .pair.server])
      | map(
          . as $items
          | {
              pair: {client: $items[0].pair.client, server: $items[0].pair.server},
              status: (if ($items | any(.status != "SUCCESS")) then "FAILED" else "SUCCESS" end),
              data: (
                $items
                | group_by(rail_key)
                | map(
                    . as $r
                    | {
                        client_dev: $r[0].case.client_dev,
                        server_dev: $r[0].case.server_dev,
                        client_ip: $r[0].case.client_ip,
                        server_ip: $r[0].case.server_ip,
                        tag_lat_avg_us: ( $r | map(select(.test_type=="tag_lat") | .metrics.lat_avg_us) | .[0] ),
                        tag_bw_avg_gbps: ( $r | map(select(.test_type=="tag_bw") | .metrics.bw_gbps) | .[0] )
                      }
                  )
              ),
              metrics: (
                {
                  total_tag_lat_avg_us: (avg($items | map(select(.test_type=="tag_lat" and .status=="SUCCESS") | .metrics.lat_avg_us)) | if .==null then null else (. * 1000 | round / 1000) end),
                  total_tag_bw_avg_gbps: (avg($items | map(select(.test_type=="tag_bw" and .status=="SUCCESS") | .metrics.bw_gbps)) | if .==null then null else (. * 1000 | round / 1000) end)
                }
              )
            }
        )
    ' "${REPORT_FILE}" >"${tmp}" 2>/dev/null || true

    if [ -s "${tmp}" ]; then
        mv "${tmp}" "${REPORT_FILE}"
    fi
}

# --- 5. Main Flow Execution ---
HOSTS_RAW=$(read_hosts_file "${HOSTS_FILE}")
if [ -z "${HOSTS_RAW}" ]; then
    echo "Error: HOSTS_FILE is empty: ${HOSTS_FILE}"
    exit 1
fi

HOSTS=()
while IFS= read -r line; do
    [ -n "${line}" ] || continue
    HOSTS+=("${line}")
done <<<"${HOSTS_RAW}"

NUM=${#HOSTS[@]}
if [ "${NUM}" -lt 2 ]; then
    echo "Error: HOSTS_FILE must contain at least 2 hosts."
    exit 1
fi
if [ $((NUM % 2)) -ne 0 ]; then
    echo "Error: host count must be even, got ${NUM}."
    exit 1
fi

echo "=== [UCX PAIR MODE] ==="
echo "  - HOSTS_FILE:  ${HOSTS_FILE}"
echo "  - WORKDIR:     ${WORKDIR}"
echo "  - REPORT_FILE: ${REPORT_FILE}"
echo "  - RAW_LOG:     ${TMP_RAW_LOG}"
echo "  - TESTS:       ${TESTS}"
echo "  - SAME_TRACK:  ${SAME_NETWORK_TRACK}"
echo "  - RDMA_MODE:   ${RDMA_MODE}"
echo "  - DEBUG:       ${DEBUG}"

echo "=== [UCX PREFLIGHT: SSH] ==="
ssh_ok_hosts=0
for host in "${HOSTS[@]}"; do
    if ssh_precheck_host "${host}"; then
        ssh_ok_hosts=$((ssh_ok_hosts + 1))
        echo "  - ${host}: OK"
        if [ "${DEBUG}" = "true" ]; then
            debug_log "[UCX][Debug] ssh_${host}.out:"
            debug_log "$(cat "${WORKDIR}/ssh_${host}.out" 2>/dev/null || true)"
        fi
    else
        echo "  - ${host}: FAIL"
        log "[UCX][Error] SSH precheck failed for ${host} on port ${SSH_PORT}"
        log "[UCX][Error] ssh stderr: $(tail_one_line "${WORKDIR}/ssh_${host}.err")"
        if [ "${DEBUG}" = "true" ]; then
            debug_log "[UCX][Debug] ssh_${host}.out:"
            debug_log "$(cat "${WORKDIR}/ssh_${host}.out" 2>/dev/null || true)"
            debug_log "[UCX][Debug] ssh_${host}.err:"
            debug_log "$(cat "${WORKDIR}/ssh_${host}.err" 2>/dev/null || true)"
        fi
    fi
done

if [ "${ssh_ok_hosts}" -lt "${NUM}" ]; then
    fatal "SSH precheck failed (${ssh_ok_hosts}/${NUM} reachable). Verify rdma-tools containers are running with the default /entry.sh and that sshd is listening on SSH_PORT=${SSH_PORT}."
fi

echo "=== [UCX PREFLIGHT: RDMA DISCOVERY] ==="

total_hosts_ok=0
for host in "${HOSTS[@]}"; do
    info=$(remote_rdma_info "${host}")
    printf '%s\n' "${info}" >"${WORKDIR}/rdma_${host}.txt"
    if [ ! -s "${WORKDIR}/rdma_${host}.txt" ]; then
        log "[UCX][Error] failed to collect RDMA info from ${host} (no IB device with IPv4 found, or ssh failed)"
        if [ "${DEBUG}" = "true" ]; then
            debug_log "[UCX][Debug] discovery stderr: ${WORKDIR}/rdma_${host}.debug"
            debug_log "$(cat "${WORKDIR}/rdma_${host}.debug" 2>/dev/null || true)"
        fi
    fi
    if [ -s "${WORKDIR}/rdma_${host}.txt" ]; then
        total_hosts_ok=$((total_hosts_ok + 1))
        if [ "${DEBUG}" = "true" ]; then
            debug_log "[UCX][Debug] rdma_${host}.txt:" 
            debug_log "$(cat "${WORKDIR}/rdma_${host}.txt" 2>/dev/null || true)"
        fi
    fi
done

if [ "${total_hosts_ok}" -lt 2 ]; then
    log "[UCX][Error] not enough hosts with usable RDMA IPv4 info (ok=${total_hosts_ok}/${NUM})."
    log "[UCX][Hint] ensure RDMA netdevs have IPv4 addresses, or set SAME_NETWORK_TRACK=false if you want cross-subnet pairing."
    fatal "RDMA discovery failed before any runnable pair was found. Check ${WORKDIR}/rdma_<host>.debug and verify SSH_PORT=${SSH_PORT}."
fi

i=0
total_executed=0
while [ "${i}" -lt "${NUM}" ]; do
    client_host="${HOSTS[$i]}"
    server_host="${HOSTS[$((i+1))]}"
    run_pair_hosts "${client_host}" "${server_host}"
    total_executed=$((total_executed + 1))
    i=$((i + 2))
done

if [ "${total_executed}" -eq 0 ]; then
    fatal "no runnable host pairs were executed after RDMA discovery/filtering. Check SAME_NETWORK_TRACK, SAME_RAIL_ONLY, RDMA_MODE, and ${WORKDIR}/rdma_<host>.txt."
fi

finalize_report

if [ "$(jq 'length' "${REPORT_FILE}" 2>/dev/null || echo 0)" -eq 0 ]; then
    fatal "report is empty: no runnable cases matched. Check DEBUG logs, SAME_NETWORK_TRACK, and ${WORKDIR}/rdma_<host>.txt."
fi

echo -e "\n======================= BENCHMARK REPORT ======================="
